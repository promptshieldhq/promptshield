

# Auth
BETTER_AUTH_SECRET=change-me-at-least-32-characters-long

# Database
POSTGRES_PASSWORD=password

# Audit log ingest (shared secret between log-fwd sidecar and server)
AUDIT_INGEST_SECRET=dev-ingest-secret

# Optional forwarding controls:
# - docker: tails docker logs from PROXY_CONTAINER_NAME
# - file:   tails PROXY_LOG_FILE (for standalone binary logs)
# - stdin:  reads from stdin
AUDIT_SERVER_URL=http://ps-server:3000
PROXY_LOG_SOURCE=docker
PROXY_CONTAINER_NAME=promptshield-proxy
PROXY_LOG_FILE=/proxy-logs/promptshield.log

# Engine auth forwarding (BFF -> engine)
ENGINE_API_KEY=dev-engine-key

# Dashboard config admin access control
# Comma-separated email addresses allowed to mutate proxy/policy settings.
CONFIG_ADMIN_EMAILS=you@example.com

POLICY_ALLOWED_DIRS=true

# Optional external proxy policy management (dashboard -> proxy API)
# POLICY_SOURCE=local_file | proxy_api
POLICY_SOURCE=local_file
PROXY_POLICY_ENDPOINT=/admin/policy
PROXY_ADMIN_TOKEN=dev-proxy-admin-token

# Optional external proxy config management (dashboard -> proxy API)
# PROXY_CONFIG_SOURCE=local_env | proxy_api
PROXY_CONFIG_SOURCE=local_env
PROXY_CONFIG_ENDPOINT=/admin/config

# Proxy — LLM provider (pick one)
PROMPTSHIELD_PROVIDER=gemini   # gemini | openai | anthropic | selfhosted
#PROMPTSHIELD_PROVIDERS=gemini,openai,anthropic,selfhosted
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# The vars below are injected by docker-compose.dev.yml directly
# DATABASE_URL      → built from POSTGRES_PASSWORD
# BETTER_AUTH_URL   → http://localhost:3000
# CORS_ORIGIN       → http://localhost:8000
# ENGINE_URL        → http://engine:4321
# PROXY_URL         → http://proxy:8080
# VITE_SERVER_URL   → http://localhost:3000
