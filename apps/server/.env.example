BETTER_AUTH_SECRET=your-secret-here-min-32-chars
BETTER_AUTH_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:8000

DATABASE_URL=postgresql://postgres:password@localhost:5432/promptshield

# External services (engine + gateway run as separate stacks)
ENGINE_URL=http://localhost:4321
ENGINE_API_KEY=dev-engine-key
GATEWAY_URL=http://localhost:8080
GATEWAY_CONFIG_SOURCE=local_env
GATEWAY_CONFIG_ENDPOINT=/admin/config
CONFIG_ADMIN_EMAILS=you@example.com

# Policy source:
# - local_file:  read/write POLICY_FILE_PATH in this repo stack
# - gateway_api: read/write external gateway policy endpoint
POLICY_SOURCE=local_file
GATEWAY_POLICY_ENDPOINT=/admin/policy
GATEWAY_ADMIN_TOKEN=dev-gateway-admin-token

# Audit forwarding controls (used by scripts/log-fwd.sh)
# Plain setup defaults: read from a local file and send to local API server.
# For Docker log tailing, set GATEWAY_LOG_SOURCE=docker and GATEWAY_CONTAINER_NAME.
AUDIT_SERVER_URL=http://localhost:3000
GATEWAY_LOG_SOURCE=file
GATEWAY_CONTAINER_NAME=promptshield-gateway
GATEWAY_LOG_FILE=../../gateway-logs/promptshield.log

POLICY_FILE_PATH=../../config/policy.yaml
POLICY_ALLOWED_DIRS=
GATEWAY_ENV_PATH=../../config/gateway.env
AUDIT_INGEST_SECRET=dev-ingest-secret
